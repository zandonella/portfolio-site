---
import "../styles/global.css";
import { Image } from "astro:assets";
import Headshot from "../assets/MichaelHeadshot.jpg";
import SocialIcons from "./SocialIcons.astro";
---

<div
    class="container mx-auto flex flex-col-reverse items-center gap-4 py-4 text-center md:flex-row md:items-start md:text-start"
>
    <div class="flex flex-col items-center gap-4 pr-4 md:items-start">
        <div>
            <h1 class="font-sans text-5xl font-bold tracking-tighter">
                Hi, I'm Michael
            </h1>
            <p
                class="mx-auto mt-4 text-lg/6 text-balance text-gray-300 md:pr-4 md:text-wrap"
            >
                New grad software engineer graduating from Oregon State
                University in
                <span class="font-bold text-emerald-500">June 2026</span>. I
                build full-stack, backend, and infrastructure-focused systems
                with TypeScript, React, Node.js, PostgreSQL, and AWS, and I'm
                seeking software engineering roles in <span
                    class="font-bold text-emerald-500">NYC Metro</span
                >.
            </p>
        </div>
        <div>
            <p class="text-gray-400">Interested in my experience?</p>
            <SocialIcons />
        </div>
    </div>
    <Image
        src={Headshot}
        alt="A headshot of Michael"
        height="250"
        class="mr-2 rounded-4xl shadow-sm ring-2 shadow-emerald-500/10 ring-emerald-500 transition-all duration-300 hover:rotate-1 hover:shadow-lg hover:ring-4 hover:shadow-emerald-500/40"
    />
</div>
