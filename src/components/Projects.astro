---
import ProjectCard from "./ProjectCard.astro";
import CatCallImage from "../assets/catcall.zando.dev.jpg";
import ZandoDevImage from "../assets/zando.dev.png";
import DiceSlayerImage from "../assets/arduino.jpg";
import IssueNavigatorIcon from "../assets/IssueNavigatorIcon.png";
import labelsImage from "../assets/labels.png";
import YTSearchImage from "../assets/yt-search.png";
import RotationsImage from "../assets/rotations-lol.png";

const projects = [
    {
        title: "Rotations.lol",
        description:
            "Full-stack web application that tracks League of Legends shop rotations and sends daily notifications when wishlisted items become available. Ingests data from the League Client, stores a normalized Postgres catalog in Supabase, and delivers transactional emails via AWS SES.",
        skills: [
            "TypeScript",
            "React",
            "Supabase",
            "PostgreSQL",
            "AWS SES",
            "Docker",
            "Tailwind CSS",
            "Node.js",
        ],
        imageURL: RotationsImage,
        live: "https://rotations.lol",
        repo: "https://github.com/zandonella/rotations-lol",
    },
    {
        title: "YouTube Transcript Search",
        description:
            "Full-stack search system that indexes YouTube video transcripts to enable timestamp-level search across entire playlists. Uses yt-dlp for ingestion, Elasticsearch (BM25) for ranking, and a React frontend to surface precise moments within videos instead of entire results.",
        skills: [
            "Python",
            "Elasticsearch",
            "React",
            "Flask",
            "APIs",
            "Information Retrieval",
        ],
        imageURL: YTSearchImage,
        repo: "https://github.com/zandonella/yt-transcript-search",
    },
    {
        title: "Issue Navigator",
        description:
            "Chrome extension that streamlines GitHub issue and pull request browsing with customizable keyboard shortcuts and advanced filtering, featuring GitHub API integration, optional OAuth authentication, and local storage for fast, secure navigation.",
        skills: [
            "JavaScript",
            "HTML",
            "CSS",
            "GitHub API",
            "Chrome Extensions",
            "OAuth 2.0",
        ],
        imageURL: IssueNavigatorIcon,
        live: "https://chromewebstore.google.com/detail/issue-navigator/pddmcdakmeciplbfgjngpemhjpjlcmbg",
        repo: "https://github.com/zandonella/IssueNavigator",
    },
    {
        title: "CatCall",
        description:
            "Microservice-based, Tinder-style cat adoption platform featuring card-based liking, location-based recommendations, and Dockerized deployment with Node.js, React, and MongoDB. Deployed live with Docker and Docker Compose.",
        skills: [
            "React",
            "Node.js",
            "Express",
            "APIs",
            "MongoDB",
            "Tailwind CSS",
            "Docker",
        ],
        imageURL: CatCallImage,
        repo: "https://github.com/zandonella/CatCall",
    },
    {
        title: "Portfolio Website",
        description:
            "Personal portfolio site built with Astro and React to showcase my work, resume, and skills, featuring a responsive design styled with Tailwind CSS.",
        skills: ["HTML", "React", "Astro", "Tailwind CSS"],
        imageURL: ZandoDevImage,
        live: "https://zando.dev",
        repo: "https://github.com/zandonella/portfolio-site",
    },
    {
        title: "Dice Slayer",
        description:
            "Turn-based dungeon crawler built for the Adafruit Circuit Playground using C++, featuring dice-based combat, upgrade mechanics, and real-time visual feedback via NeoPixels.",
        skills: ["Arduino", "C++"],
        imageURL: DiceSlayerImage,
        repo: "https://github.com/zandonella/Dice-Slayer",
    },
    {
        title: "CAT Label Maker",
        description:
            "Python-based command-line tool that generates printable PDF labels with images from product catalog numbers, designed for small-scale inventory systems requiring efficient label generation.",
        skills: ["Python"],
        imageURL: labelsImage,
    },
];
---

<div class="container mt-10">
    <h1 class="text-center font-sans text-3xl font-bold">Projects</h1>
    <div class="mt-4 grid grid-cols-1 gap-4 md:grid-cols-2">
        {
            projects.map((project) => (
                <ProjectCard
                    title={project.title}
                    description={project.description}
                    skills={project.skills}
                    imageURL={project.imageURL}
                    live={project.live}
                    repo={project.repo}
                />
            ))
        }
    </div>
</div>
