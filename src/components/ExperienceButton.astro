---
const { title, active, left, right } = Astro.props;
let addClass = "";
if (left) {
    addClass += "rounded-l-lg";
}
if (right) {
    addClass += "rounded-r-lg";
}
---

<button
    id={title.toLowerCase() + "Button"}
    data-active={active ? "true" : undefined}
    class={`text-md font-semibold bg-transparent py-1 cursor-pointer data-active:bg-background hover:bg-background/80 focus-visible:bg-background/80 hover:transition-colors hover:duration-200 ${addClass}`}
    >{title}</button
>
